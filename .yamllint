# yamllint configuration for this repo.
#
# Tuned for GitHub Actions workflow files and project YAML (mkdocs,
# issue templates). Mirrors the canonical config from standard-tooling.

extends: default

rules:
  # GHA workflow files don't lead with `---`.
  document-start: disable

  # GHA's `on:` key is YAML's truthy value. Disable key checking so
  # the standard GHA trigger syntax is not flagged.
  truthy:
    allowed-values:
      - "true"
      - "false"
    check-keys: false

  # 120 chars for general YAML; workflow files are exempt because they
  # carry action references and inline expressions that can't be split.
  line-length:
    max: 120
    level: error
    ignore: |
      **/.github/workflows/**
      .github/workflows/**
